---
import '../styles/tokens.css';
import '../styles/typography.css';
import '../styles/components.css';
import '../styles/styleguide.css';
---
<html lang="cs">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Login</title>
  </head>
  <body>
    <div class="login-screen">
      <div class="login-box">
        <div class="card">
          <h1>Přihlášení</h1>
          <p class="alert alert-error">Nesprávné přihlašovací údaje.</p>
          <div class="form-group">
            <label for="email">E-mail</label>
            <input class="input" type="email" id="email" placeholder="vas@email.cz" />
          </div>
          <div class="form-group">
            <label for="password">Heslo</label>
            <input class="input" type="password" id="password" placeholder="••••••••" />
            <a href="#" class="forgot">Zapomněli jste heslo?</a>
          </div>
          <button class="btn btn-primary btn-block">Přihlásit se</button>
        </div>
      </div>
    </div>
  </body>
</html>
