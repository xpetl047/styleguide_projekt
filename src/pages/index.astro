---
import '../styles/tokens.css';
import '../styles/typography.css';
import '../styles/components.css';
import '../styles/styleguide.css';
import '../styles/typography.css';
---
<html lang="cs">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Style Guide</title>
  </head>
  <body>
    <div class="container">
    <h1>Style Guide</h1>

    <h2>Pages</h2>
    <ul>
      <li><a href={`${import.meta.env.BASE_URL}/login`}>Login</a></li>
    </ul>
    <h2>Components</h2>
    <div class="component-item">
      <h3>Card</h3>
      <div class="component-preview">
        <div class="card">Card content</div>
      </div>

      <div class="component-item">
        <h3>Button</h3>
        <div class="component-preview">
          <button class="btn btn-primary">Click me</button>
        </div>
        <pre>
          <code>
            &lt;button class=&quot;btn btn-primary&quot;&gt;Click me&lt;/button&gt;
          </code>
        </pre>
      </div>

      <div class="component-item">
        <h3>Input</h3>
        <div class="component-preview">
          <input type="text" class="input" placeholder="Enter text" />
        </div>
        <pre>
          <code>
            &lt;input type=&quot;text&quot; class=&quot;input&quot; placeholder=&quot;Enter text&quot; /&gt;
          </code>
        </pre>
      </div>

      <div class="component-item">
        <h3>Grid (12 cols)</h3>
        <div class="component-preview">
          <div class="row">
            <div class="col-1 grid-col-demo">1</div>
            <div class="col-1 grid-col-demo">2</div>
            <div class="col-1 grid-col-demo">3</div>
            <div class="col-1 grid-col-demo">4</div>
            <div class="col-1 grid-col-demo">5</div>
            <div class="col-1 grid-col-demo">6</div>
            <div class="col-1 grid-col-demo">7</div>
            <div class="col-1 grid-col-demo">8</div>
            <div class="col-1 grid-col-demo">9</div>
            <div class="col-1 grid-col-demo">10</div>
            <div class="col-1 grid-col-demo">11</div>
            <div class="col-1 grid-col-demo">12</div>
          </div>
          <div class="row grid-row-demo">
            <div class="col-4 grid-col-demo">col-4</div>
            <div class="col-8 grid-col-demo grid-col-demo--alt">col-8</div>
          </div>
          <div class="row grid-row-demo">
            <div class="col-6 grid-col-demo">col-6</div>
            <div class="col-6 grid-col-demo grid-col-demo--alt">col-6</div>
          </div>
        </div>
        <pre>
          <code>
            &lt;div class=&quot;row&quot;&gt;
              &lt;div class=&quot;col-4&quot;&gt;...&lt;/div&gt;
              &lt;div class=&quot;col-8&quot;&gt;...&lt;/div&gt;
            &lt;/div&gt;
          </code>
        </pre>
      </div>

    </div>

    <div class="component-item">
      <h3>Input</h3>
      <div class="component-preview">
        <input class="input" type="text" placeholder="Zadejte text..." />
      </div>
      <pre>
        <code>
          &lt;input class=&quot;input&quot; type=&quot;text&quot; placeholder=&quot;Zadejte text...&quot; /&gt;
        </code>
      </pre>
    </div>

    <div class="component-item">
      <h3>Alert</h3>
      <div class="component-preview">
        <p class="alert alert-error">Nesprávné přihlašovací údaje.</p>
      </div>
      <pre>
        <code>
          &lt;p class=&quot;alert alert-error&quot;&gt;Text chyby.&lt;/p&gt;
        </code>
      </pre>
    </div>

    <div class="component-item">
      <h3>Grid (12 cols)</h3>
      <div class="component-preview">
        <div class="row">
          <div class="col-1 grid-col-demo">1</div>
          <div class="col-1 grid-col-demo">2</div>
          <div class="col-1 grid-col-demo">3</div>
          <div class="col-1 grid-col-demo">4</div>
          <div class="col-1 grid-col-demo">5</div>
          <div class="col-1 grid-col-demo">6</div>
          <div class="col-1 grid-col-demo">7</div>
          <div class="col-1 grid-col-demo">8</div>
          <div class="col-1 grid-col-demo">9</div>
          <div class="col-1 grid-col-demo">10</div>
          <div class="col-1 grid-col-demo">11</div>
          <div class="col-1 grid-col-demo">12</div>
        </div>
        <div class="row grid-row-demo">
          <div class="col-4 grid-col-demo">col-4</div>
          <div class="col-8 grid-col-demo grid-col-demo--alt">col-8</div>
        </div>
        <div class="row grid-row-demo">
          <div class="col-6 grid-col-demo">col-6</div>
          <div class="col-6 grid-col-demo grid-col-demo--alt">col-6</div>
        </div>
      </div>
      <pre>
        <code>
          &lt;div class=&quot;row&quot;&gt;
            &lt;div class=&quot;col-4&quot;&gt;...&lt;/div&gt;
            &lt;div class=&quot;col-8&quot;&gt;...&lt;/div&gt;
          &lt;/div&gt;
        </code>
      </pre>
    </div>
    </div>
  </body>
</html>
